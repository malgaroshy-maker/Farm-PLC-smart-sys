# ===========================================
# Algaroshy Farm — Environment Configuration
# ===========================================
# Copy this file to .env and fill in values.
# DO NOT commit the actual .env file.

# -------------------------------------------
# General
# -------------------------------------------
APP_ENV=development          # development | staging | production
APP_DEBUG=true
FARM_TIMEZONE=Africa/Tripoli
DEFAULT_LANGUAGE=ar          # ar | en

# -------------------------------------------
# Backend API
# -------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
SECRET_KEY=change-me-to-a-real-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# -------------------------------------------
# Database
# -------------------------------------------
# SQLite (development/simulation)
DATABASE_URL=sqlite:///./farm.db

# PostgreSQL (staging/production)
# DATABASE_URL=postgresql://user:password@localhost:5432/algaroshy_farm

# -------------------------------------------
# Simulator
# -------------------------------------------
SIMULATOR_ENABLED=true
SIMULATOR_TICK_INTERVAL_MS=1000
SIMULATOR_MODE=normal         # normal | accelerated | scenario

# -------------------------------------------
# WebSocket
# -------------------------------------------
WS_PORT=8001
WS_HEARTBEAT_INTERVAL_SEC=30

# -------------------------------------------
# MQTT (Edge/PLC Integration — optional)
# -------------------------------------------
# MQTT_BROKER_HOST=localhost
# MQTT_BROKER_PORT=1883
# MQTT_TOPIC_PREFIX=farm/

# -------------------------------------------
# Notifications
# -------------------------------------------
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=alerts@algaroshyfarm.com
# EMAIL_PASSWORD=

# SMS_GATEWAY_URL=
# SMS_API_KEY=
# SMS_FROM_NUMBER=

# -------------------------------------------
# PLC Adapter (Phase 7+)
# -------------------------------------------
# PLC_PROTOCOL=modbus          # modbus | opcua
# PLC_HOST=192.168.1.100
# PLC_PORT=502

# -------------------------------------------
# AI Services (AI_FEATURES.md)
# -------------------------------------------
# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_TOKENS=2048
GEMINI_TEMPERATURE=0.3

# Weather API (OpenWeatherMap)
WEATHER_API_KEY=your-openweathermap-api-key-here
WEATHER_API_PROVIDER=openweathermap    # openweathermap | weatherapi
WEATHER_LATITUDE=32.8872
WEATHER_LONGITUDE=13.1803
WEATHER_FETCH_INTERVAL_HOURS=3

# AI Feature Toggles (true/false)
AI_ALARM_ASSISTANT_ENABLED=true
AI_SMART_SCHEDULING_ENABLED=true
AI_PREDICTIVE_MAINTENANCE_ENABLED=true
AI_ANOMALY_DETECTION_ENABLED=true
AI_WEATHER_ADVISOR_ENABLED=true
AI_WATER_OPTIMIZER_ENABLED=true
AI_DAILY_INSIGHTS_ENABLED=true
AI_CROP_VISION_ENABLED=false           # Requires camera hardware
AI_VOICE_CONTROL_ENABLED=false          # Future phase
AI_SEASONAL_LEARNING_ENABLED=false      # Requires 30+ days of data

# AI Insights Schedule
AI_DAILY_REPORT_TIME=06:00             # Local time (Africa/Tripoli)
AI_OFFLINE_FALLBACK=true               # Use templates when API unavailable

# -------------------------------------------
# Frontend
# -------------------------------------------
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8001
